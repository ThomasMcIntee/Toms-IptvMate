{
  "name": "toms-iptvmate",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop": "node scripts/run-desktop-with-vite.cjs --mode preview --host 127.0.0.1 --port 4173",
    "desktop:file": "electron .",
    "desktop:dev": "vite --host 127.0.0.1 --port 5173",
    "desktop:dev.all": "npm run desktop:dev:all",
    "desktop:dev:all": "node scripts/run-desktop-with-vite.cjs --mode dev --host 127.0.0.1 --port 5173",
    "desktop:build": "npm run build && npm run desktop",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "webos:sync": "node scripts/sync-webos-build.cjs",
    "webos:package": "npm run build && npm run webos:sync && npx ares-package webos/",
    "postinstall": "node scripts/fix-webos-cli-rimraf.cjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.0.0",
    "hls.js": "^1.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "shaka-player": "^5.1.10"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "@webos-tools/cli": "^3.2.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "typescript": "^5.4.0",
    "vite": "^8.0.16",
    "wait-on": "^8.0.5"
  },
  "overrides": {
    "@webos-tools/cli": {
      "rimraf": "3.0.2"
    }
  }
}
